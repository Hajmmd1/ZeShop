@model Product


  <div class="col-6 col-md-4">
                        <!-- کارت محصول -->
                        <div class="card product-wap rounded-0 h-100 border-0 shadow-sm">
                            <!-- بخش تصویر + overlay (مهم: .card.rounded-0 به عنوان والد position:relative) -->
                            <div class="card rounded-0 border-0">
                                <img class="card-img rounded-0 img-fluid"
                                     src="/images/@(Model.Id).jpg"
                                     alt="@Model.Name"
                                     style="height: 250px; object-fit: cover; width: 100%; display: block;">
                                <!-- overlay که روی تصویر ظاهر می‌شود -->
                                <div class="card-img-overlay rounded-0 product-overlay d-flex align-Models-center justify-content-center">
                                    <ul class="list-unstyled padd-r-0">
                                        <li>
                                            <a class="btn btn-success text-white" href="#" title="افزودن به علاقه‌مندی">
                                                <i class="far fa-heart"></i>
                                            </a>
                                        </li>
                                        <li>
                                            <a class="btn btn-success text-white mt-2"
                                               asp-action="Detail"
                                               asp-controller="Home"
                                               asp-route-id="@Model.Id"
                                               title="مشاهده جزئیات">
                                                <i class="far fa-eye"></i>
                                            </a>
                                        </li>
                                        <li>
                                            <a class="btn btn-success text-white mt-2"
                                               asp-controller="Home"
                                               asp-action="AddToCart"
                                               asp-route-ProductId="@Model.Item.Id"
                                               title="افزودن به سبد خرید">
                                                <i class="fas fa-cart-plus"></i>
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                            <!-- بدنه کارت -->
                            <div class="card-body d-flex flex-column">
                                <a asp-action="Detail"
                                   asp-controller="Home"
                                   asp-route-id="@Model.Id"
                                   class="h3 text-decoration-none text-dark stretched-link-block mb-2">
                                    @Model.Name
                                </a>
                                <!-- دایره‌های رنگی -->
                                <ul class="list-unstyled d-flex justify-content-between mb-0 padd-r-0 mt-auto">
                                    <li class="pt-2">
                                        <span class="product-color-dot color-dot-red rounded-circle d-inline-block ml-1"></span>
                                        <span class="product-color-dot color-dot-blue rounded-circle d-inline-block ml-1"></span>
                                        <span class="product-color-dot color-dot-black rounded-circle d-inline-block ml-1"></span>
                                        <span class="product-color-dot color-dot-light rounded-circle d-inline-block ml-1"></span>
                                        <span class="product-color-dot color-dot-green rounded-circle d-inline-block ml-1"></span>
                                    </li>
                                </ul>
                                <!-- قیمت -->
                                <p class="text-center mb-0 mt-2 fw-bold text-success fs-5">
                                    @Model.Item.Price.ToString("N0") تومان
                                </p>
                            </div>
                        </div>
                    </div>