@model IEnumerable<Address>
@{
    ViewData["Title"] = "انتخاب آدرس";
}

<style>
    /* انیمیشن ورود ملایم برای کل محتوای اصلی */
    .address-list-container {
        animation: fadeInUp 0.6s ease both;
    }

    /* هر کارت با یک حالت سایه و hover نرم */
    .address-card {
        transition: all 0.3s ease;
        border: 1px solid #e9ecef;
    }

        .address-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.1) !important;
            border-color: #198754;
        }

    /* دکمه‌ها با افکت hover */
    .btn-choose:hover {
        background-color: #198754;
        color: #fff !important;
    }

    .btn-edit:hover, .btn-delete:hover {
        transform: scale(1.05);
    }

    /* آیکن شناور برای حالت خالی */
    .empty-icon {
        animation: float 3s ease-in-out infinite;
        font-size: 5rem;
        color: #ced4da;
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-10px);
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* دکمه افزودن با پالس ملایم */
    .btn-add-pulse {
        animation: softPulse 2s infinite;
    }

    @@keyframes softPulse {
        0% {
            box-shadow: 0 0 0 0 rgba(25,135,84,0.4);
        }

        70% {
            box-shadow: 0 0 0 10px rgba(25,135,84,0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(25,135,84,0);
        }
    }
</style>

<div class="container py-5 address-list-container">
    <h1 class="h2 border-bottom pb-3 mb-4">آدرس‌های من</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="row">
        <div class="col-md-8 offset-md-2">
            <a asp-action="AddAddress" class="btn btn-success mb-3 rounded-3 px-4 btn-add-pulse">
                <i class="fas fa-plus me-2"></i>افزودن آدرس جدید
            </a>

            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <div class="empty-icon">
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                    <p class="mt-3 fs-5">هنوز آدرسی ثبت نکرده‌اید</p>
                    <p class="small">با کلیک روی دکمه بالا اولین آدرس خود را ثبت کنید.</p>
                </div>
            }
            else
            {
                foreach (var addr in Model)
                {
                    <div class="card border-0 shadow-sm rounded-3 mb-3 address-card">
                        <div class="card-body">
                            <h5 class="fw-bold">@addr.Province، @addr.City</h5>
                            <p class="text-muted small mb-1">@addr.FullAddress</p>
                            <p class="text-muted small mb-0">
                                <i class="fas fa-mail-bulk me-1"></i>@addr.PostalCode
                                <span class="mx-2">|</span>
                                <i class="fas fa-phone me-1"></i>@addr.Phone
                            </p>
                        </div>
                        <div class="card-footer bg-white border-0 d-flex justify-content-between align-items-center">
                            <a asp-controller="Home" asp-action="SelectAddress" asp-route-addressId="@addr.AddressId"
                               class="btn btn-outline-success btn-sm rounded-3 btn-choose">
                                <i class="fas fa-check me-1"></i> انتخاب
                            </a>
                            <div>
                                <a asp-action="EditAddress" asp-route-addressId="@addr.AddressId"
                                   class="btn btn-outline-secondary btn-sm me-1 rounded-3 btn-edit" title="ویرایش">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="DeleteAddress" asp-route-addressId="@addr.AddressId" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-3 btn-delete"
                                            onclick="return confirm('آیا از حذف این آدرس مطمئن هستید؟')">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>