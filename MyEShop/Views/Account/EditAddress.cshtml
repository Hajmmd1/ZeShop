@model AddAddressViewModel
@{
    ViewData["Title"] = "افزودن آدرس جدید";
}

<style>
    .form-group-staggered {
        opacity: 0;
        animation: fadeInUp 0.6s ease forwards;
    }

        .form-group-staggered:nth-child(1) {
            animation-delay: 0.1s;
        }

        .form-group-staggered:nth-child(2) {
            animation-delay: 0.2s;
        }

        .form-group-staggered:nth-child(3) {
            animation-delay: 0.3s;
        }

        .form-group-staggered:nth-child(4) {
            animation-delay: 0.4s;
        }

        .form-group-staggered:nth-child(5) {
            animation-delay: 0.5s;
        }

        .form-group-staggered:nth-child(6) {
            animation-delay: 0.6s;
        }
    /* دکمه‌ها */

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .submit-btn {
        transition: 0.3s;
    }

        .submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(25,135,84,0.4);
        }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow rounded-3">
                <div class="card-header bg-success text-white text-center py-3 border-0">
                    <h4 class="mb-0"><i class="fas fa-plus-circle me-2"></i>افزودن آدرس جدید</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="AddAddress" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                        <div class="mb-3 form-group-staggered">
                            <label asp-for="Province" class="form-label fw-bold"></label>
                            <input asp-for="Province" class="form-control rounded-3" placeholder="استان">
                            <span asp-validation-for="Province" class="text-danger small"></span>
                        </div>
                        <div class="mb-3 form-group-staggered">
                            <label asp-for="City" class="form-label fw-bold"></label>
                            <input asp-for="City" class="form-control rounded-3" placeholder="شهر">
                            <span asp-validation-for="City" class="text-danger small"></span>
                        </div>
                        <div class="mb-3 form-group-staggered">
                            <label asp-for="PostalCode" class="form-label fw-bold"></label>
                            <input asp-for="PostalCode" class="form-control rounded-3" placeholder="کد پستی">
                            <span asp-validation-for="PostalCode" class="text-danger small"></span>
                        </div>
                        <div class="mb-3 form-group-staggered">
                            <label asp-for="Phone" class="form-label fw-bold"></label>
                            <input asp-for="Phone" class="form-control rounded-3" placeholder="شماره تلفن">
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="mb-3 form-group-staggered">
                            <label asp-for="FullAddress" class="form-label fw-bold"></label>
                            <textarea asp-for="FullAddress" class="form-control rounded-3" rows="3" placeholder="آدرس کامل"></textarea>
                            <span asp-validation-for="FullAddress" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between form-group-staggered">
                            <a asp-action="AddressList" class="btn btn-outline-secondary rounded-3 px-4">
                                <i class="fas fa-arrow-right me-2"></i>بازگشت
                            </a>
                            <button type="submit" class="btn btn-success rounded-3 px-4 submit-btn">
                                <i class="fas fa-save me-2"></i>ذخیره آدرس
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>