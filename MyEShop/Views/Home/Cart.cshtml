@model Order
@{
    ViewData["Title"] = "سبد خرید";
}

<style>
    /* انیمیشن ورود ردیف‌های جدول */
    .cart-item-row {
        animation: fadeInUp 0.5s ease backwards;
    }

        .cart-item-row:nth-child(1) {
            animation-delay: 0.1s;
        }

        .cart-item-row:nth-child(2) {
            animation-delay: 0.2s;
        }

        .cart-item-row:nth-child(3) {
            animation-delay: 0.3s;
        }

        .cart-item-row:nth-child(4) {
            animation-delay: 0.4s;
        }

        .cart-item-row:nth-child(5) {
            animation-delay: 0.5s;
        }

    /* دکمه نهایی کردن – درخشش و پالس */
    .glow-btn {
        position: relative;
        z-index: 1;
        transition: 0.3s;
        overflow: hidden;
    }

        .glow-btn::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.3) 0%, transparent 60%);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .glow-btn:hover::after {
            opacity: 1;
        }

        .glow-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(25,135,84,0.4);
        }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .card-summary {
        animation: fadeIn 0.6s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }
</style>

<div class="container py-5">
    <div class="row">
        <div class="col-12">
            <h1 class="h2 border-bottom pb-3 mb-5">سبد خرید</h1>
        </div>
    </div>

    @if (Model != null && Model.OrderDetails.Any())
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead class="bg-light">
                            <tr>
                                <th scope="col" class="border-0 ps-0" style="min-width: 100px;">محصول</th>
                                <th scope="col" class="border-0">قیمت</th>
                                <th scope="col" class="border-0">تعداد</th>
                                <th scope="col" class="border-0">مجموع</th>
                                <th scope="col" class="border-0 text-center">حذف</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderDetails)
                            {
                                <tr class="cart-item-row">
                                    <td class="ps-0">
                                        <div class="d-flex align-items-center">
                                            <img src="@($"/images/{item.Product.Id}.jpg")"
                                                 alt="@item.Product.Name"
                                                 class="img-fluid rounded-1 me-3"
                                                 style="width: 80px; height: 80px; object-fit: cover;">
                                            <div>
                                                <a asp-action="Detail" asp-controller="Home" asp-route-id="@item.ProductId"
                                                   class="h6 text-decoration-none text-dark">@item.Product.Name</a>
                                                <div class="mt-2">
                                                    <span class="product-color-dot color-dot-red rounded-circle d-inline-block me-1"></span>
                                                    <span class="product-color-dot color-dot-blue rounded-circle d-inline-block me-1"></span>
                                                    <span class="product-color-dot color-dot-black rounded-circle d-inline-block"></span>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="align-middle"><span class="fw-bold">@item.Price.ToString("N0") تومان</span></td>
                                    <td class="align-middle">
                                        <div class="input-group input-group-sm" style="max-width: 120px;">
                                            <button class="btn btn-outline-secondary" type="button"><i class="fas fa-minus"></i></button>
                                            <input type="text" class="form-control text-center" value="@item.Count" readonly>
                                            <button class="btn btn-outline-secondary" type="button"><i class="fas fa-plus"></i></button>
                                        </div>
                                    </td>
                                    <td class="align-middle fw-bold text-success">@((item.Count * item.Price).ToString("N0")) تومان</td>
                                    <td class="align-middle text-center">
                                        <a asp-controller="Home" asp-action="RemoveItem" asp-route-DatailId="@item.DetailId"
                                           class="btn btn-sm btn-outline-danger rounded-3" title="حذف">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-success rounded-3 px-4">
                        <i class="fas fa-arrow-right me-2"></i>ادامه خرید
                    </a>
                    <button type="button" class="btn btn-outline-secondary rounded-3 px-4">
                        <i class="fas fa-sync-alt me-2"></i>بروزرسانی سبد
                    </button>
                </div>
            </div>

            <div class="col-lg-4 mt-5 mt-lg-0">
                <div class="card border-0 shadow rounded-3 card-summary">
                    <div class="card-body p-4">
                        <h2 class="h4 border-bottom pb-3 mb-4">خلاصه سفارش</h2>
                        <div class="d-flex justify-content-between mb-2">
                            <span>جمع سبد خرید</span>
                            <span>@Model.OrderDetails.Sum(c => c.Count * c.Price).ToString("N0") تومان</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>هزینه حمل</span>
                            <span>۵۰,۰۰۰ تومان</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 text-danger">
                            <span>تخفیف</span>
                            <span>- ۱۰۰,۰۰۰ تومان</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-4 fw-bold h5">
                            <span>مبلغ قابل پرداخت</span>
                            <span class="text-success">
                                @((Model.OrderDetails.Sum(c => c.Count * c.Price) + 50000 - 100000).ToString("N0")) تومان
                            </span>
                        </div>

                        <div class="input-group mb-4">
                            <input type="text" class="form-control" placeholder="کد تخفیف">
                            <button class="btn btn-success rounded-3 px-3" type="button">اعمال</button>
                        </div>

                        <a asp-controller="Account" asp-action="AddressList"
                           class="btn btn-success w-100 py-3 rounded-3 fw-bold glow-btn">
                            <i class="fas fa-credit-card me-2"></i>نهایی کردن خرید
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row py-5">
            <div class="col-md-8 m-auto text-center">
                <i class="fas fa-cart-arrow-down text-muted" style="font-size: 6rem;"></i>
                <h2 class="h3 mt-4">سبد خرید شما خالی است</h2>
                <p class="text-muted mb-4">محصولات جذاب ما را ببینید و سبد خود را پر کنید.</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-success rounded-3 px-5 py-3">
                    رفتن به فروشگاه
                </a>
            </div>
        </div>
    }
</div>