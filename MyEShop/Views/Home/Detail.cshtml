@model DetailsViewMode
@{
    ViewData["Title"] = "جزئیات محصول";
}

<!-- Open Content -->
<section class="bg-light">
    <div class="container pb-5">
        <!-- دکمه بازگشت -->
        <div class="row pt-4">
            <div class="col-12">
                <a href="javascript:history.back()" class="btn btn-outline-success rounded-3 px-4">
                    <i class="fas fa-arrow-right me-2"></i> بازگشت
                </a>
            </div>
        </div>

        <div class="row mt-3">
            <!-- تصویر محصول -->
            <div class="col-lg-5 mt-5">
                <div class="card mb-3">
                    <img class="card-img img-fluid" src="@($"/images/{Model.Product.Id}.jpg")" alt="@Model.Product.Name" id="product-detail">
                </div>
            </div>

            <!-- اطلاعات محصول -->
            <div class="col-lg-7 mt-5">
                <div class="card">
                    <div class="card-body">
                        <h1 class="h2">@Model.Product.Name</h1>

                        <!-- دسته‌بندی‌های این محصول -->
                        @if (Model.Category != null && Model.Category.Any())
                        {
                            <div class="mb-3">
                                <h6 class="d-inline">دسته‌بندی‌ها:</h6>
                                @foreach (var cat in Model.Category)
                                {
                                    <a href="/Group/@cat.Id/@cat.Name"
                                       class="badge bg-light text-dark text-decoration-none ms-1">
                                        @cat.Name
                                    </a>
                                }
                            </div>
                        }

                        <h6>توضیحات:</h6>
                        <p>@Model.Product.Description</p>

                        <ul class="list-inline padd-r-0">
                            <li class="list-inline-item">
                                <h6>تعداد موجودی :</h6>
                            </li>
                            <li class="list-inline-item">
                                <p class="text-muted"><strong>@Model.Product.Item.QuantityInStock</strong></p>
                            </li>
                        </ul>
                        <p class="h3 py-2">@Model.Product.Item.Price.ToString("N0") تومان</p>

                        <!-- انتخاب تعداد -->
                        <div class="row">
                            <div class="col-auto">
                                <ul class="list-inline pb-3 padd-r-0">
                                    <li class="list-inline-item text-right">تعداد</li>
                                    <li class="list-inline-item"><span class="btn btn-success" id="btn-minus">-</span></li>
                                    <li class="list-inline-item"><span class="badge bg-secondary" id="var-value">1</span></li>
                                    <li class="list-inline-item"><span class="btn btn-success" id="btn-plus">+</span></li>
                                </ul>
                            </div>
                        </div>

                        <!-- دکمه‌ها -->
                        <div class="row pb-3">
                            <div class="col d-grid">
                                <button type="button" class="btn btn-success btn-lg" name="submit" value="buy">خرید</button>
                            </div>
                            <div class="col d-grid">
                                <a class="btn btn-success btn-lg"
                                   asp-controller="Home" asp-action="AddToCart"
                                   asp-route-ProductId="@Model.Product.Item.Id">
                                    افزودن به سبد
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Close Content -->
<!-- Start Article (محصولات مرتبط) -->
@if (Model.Products != null && Model.Products.Any())
{
    <section class="py-5">
        <div class="container">
            <div class="row text-left p-2 pb-3">
                <h4>محصولات مرتبط</h4>
            </div>

            <div id="carousel-related-product">
                @foreach (var p in Model.Products)
                {
                    <div class="p-2 pb-3">
                        <div class="product-wap card rounded-0 h-100 border-0 shadow-sm">
                            <div class="card rounded-0 border-0">
                                <img class="card-img rounded-0 img-fluid"
                                     src="/images/@(p.Id).jpg"
                                     alt="@p.Name"
                                     style="height: 220px; object-fit: cover; width: 100%; display: block;">
                                <div class="card-img-overlay rounded-0 product-overlay d-flex align-items-center justify-content-center">
                                    <ul class="list-unstyled padd-r-0">
                                        <li>
                                            <a class="btn btn-success text-white mt-2" asp-action="Detail" asp-route-id="@p.Id" title="مشاهده جزئیات">
                                                <i class="far fa-eye"></i>
                                            </a>
                                        </li>
                                        <li>
                                            <a class="btn btn-success text-white mt-2" asp-controller="Home" asp-action="AddToCart" asp-route-itemId="@p.ItemId" title="افزودن به سبد خرید">
                                                <i class="fas fa-cart-plus"></i>
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                            <div class="card-body d-flex flex-column">
                                <a asp-action="Detail" asp-route-id="@p.Id" class="h3 text-decoration-none text-dark mb-2">@p.Name</a>
                                <ul class="list-unstyled d-flex justify-content-between mb-0 padd-r-0 mt-auto">
                                    <li class="pt-2">
                                        <span class="product-color-dot color-dot-red rounded-circle d-inline-block ml-1"></span>
                                        <span class="product-color-dot color-dot-blue rounded-circle d-inline-block ml-1"></span>
                                        <span class="product-color-dot color-dot-black rounded-circle d-inline-block ml-1"></span>
                                        <span class="product-color-dot color-dot-light rounded-circle d-inline-block ml-1"></span>
                                        <span class="product-color-dot color-dot-green rounded-circle d-inline-block ml-1"></span>
                                    </li>
                                </ul>
                                <ul class="list-unstyled d-flex justify-content-center mb-1 padd-r-0 mt-2">
                                    <li>
                                        <i class="text-warning fa fa-star"></i>
                                        <i class="text-warning fa fa-star"></i>
                                        <i class="text-warning fa fa-star"></i>
                                        <i class="text-warning fa fa-star"></i>
                                        <i class="text-muted fa fa-star"></i>
                                    </li>
                                </ul>
                                <p class="text-center mb-0 mt-2 fw-bold text-success fs-6">
                                    @Model.Product.Item.Price.ToString("N0") تومان
                                </p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}
<!-- End Article -->
<!-- Start Slider Script -->
@section Scripts
{
    <script src="~/assets/js/slick.min.js"></script>
    <script>
        $('#carousel-related-product').slick({
        infinite: true,
        arrows: false,
        slidesToShow: 4,
        slidesToScroll: 3,
        dots: true,
        rtl: true,
        responsive: [{
        breakpoint: 1024,
        settings: {
        slidesToShow: 3,
        slidesToScroll: 3
        }
        },
        {
        breakpoint: 600,
        settings: {
        slidesToShow: 2,
        slidesToScroll: 3
        }
        },
        {
        breakpoint: 480,
        settings: {
        slidesToShow: 2,
        slidesToScroll: 3
        }
        }
        ]
        });
    </script>
}
<!-- End Slider Script -->