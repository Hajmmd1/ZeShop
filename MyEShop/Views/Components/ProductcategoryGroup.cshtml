@model IEnumerable<ShopgroupViewModel>

<h1 class="h2 pb-4">دسته بندی</h1>
<ul class="list-unstyled padd-r-0">
  @foreach (var item in Model)
    {
        @if (item.ProductCount >= 1)
        {

            <li class="pb-3">
                <a class="d-flex justify-content-between align-items-center text-decoration-none h5 fw-bold mb-0 text-dark"
                   href="/Group/@item.GroupId/@item.Name"
                   style="width: 100%; gap: 0.5rem;">
                    <span>@item.Name</span>
                    <span class="badge bg-success rounded-pill">@item.ProductCount</span>
                </a>
            </li>
        }
     
    }  
  
  
</ul>