
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - پنل مدیریت</title>

    <link rel="stylesheet" href="~/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/assets/css/fontawesome.min.css" />
    <link rel="stylesheet" href="~/assets/css/fonts.css" />   <!-- ← اضافه شد (فونت اصلی) -->
    <!-- استایل اختصاصی ادمین (بعد از فونت‌ها) -->
    <link rel="stylesheet" href="~/assets/css/admin.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- سایدبار -->
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-header">
            <i class="fas fa-gem"></i> پنل مدیریت
        </div>
        <nav class="nav flex-column mt-2">
            <a asp-controller="Admin" asp-action="Dashboard" class="nav-link">
                <i class="fas fa-tachometer-alt"></i> داشبورد
            </a>
            <a asp-controller="Admin" asp-action="Orders" class="nav-link">
                <i class="fas fa-shopping-cart"></i> سفارش‌ها
            </a>
            <a asp-controller="Admin" asp-action="Products" class="nav-link">
                <i class="fas fa-box"></i> محصولات
            </a>
            <a asp-controller="Admin" asp-action="Categories" class="nav-link">
                <i class="fas fa-list"></i> دسته‌بندی‌ها
            </a>
            <a asp-controller="Admin" asp-action="Users" class="nav-link">
                <i class="fas fa-users"></i> کاربران
            </a>
            <a asp-controller="Account" asp-action="Logout" class="nav-link text-danger mt-3">
                <i class="fas fa-sign-out-alt"></i> خروج
            </a>
        </nav>
    </aside>

    <!-- تاپ بار -->
    <header class="admin-topbar">
        <button class="menu-toggle" id="menuToggle">
            <i class="fas fa-bars"></i>
        </button>
        <div class="d-flex align-items-center gap-3">
            <span class="text-muted small">خوش آمدید، مدیر ارشد</span>
            <i class="fas fa-user-circle fs-4 text-success"></i>
        </div>
    </header>

    <!-- محتوای اصلی -->
    <main class="admin-main admin-page-enter">
        @RenderBody()
    </main>

    <!-- اسکریپت‌ها -->
    <script src="~/assets/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/js/admin.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>